// ===============================
// ENVELOPE CLICK
// ===============================

let opened = false;


envelope.addEventListener("click",()=>{


    if(opened) return;


    opened = true;


    envelope.classList.add("open");


    setTimeout(()=>{


        letter.classList.add("show");


        startTyping();


    },1500);



    startMusic();


});





// ===============================
// TYPEWRITER
// ===============================

let index = 0;


function startTyping(){

    typewriter.innerHTML = "";

    index = 0;

    typing();

}



function typing(){


    if(index < loveLetter.length){


        typewriter.innerHTML +=
        loveLetter.charAt(index);


        index++;


        setTimeout(
            typing,
            35
        );


    }else{


        loveBtn.style.display="block";

        startConfetti();

    }


}





// ===============================
// MUSIC SYSTEM
// ===============================

let playing = false;



function startMusic(){


    bgMusic.volume = 0.5;


    bgMusic.play()

    .then(()=>{


        playing = true;


        musicBtn.innerHTML="🎶";


    })


    .catch(error=>{


        console.log(
        "Music blocked:",
        error
        );


    });


}





musicBtn.addEventListener("click",(e)=>{


    e.stopPropagation();



    if(playing){


        bgMusic.pause();


        playing=false;


        musicBtn.innerHTML="🎵";


    }

    else{


        startMusic();


    }


});
